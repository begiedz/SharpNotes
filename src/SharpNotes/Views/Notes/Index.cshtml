@{
    ViewData["Title"] = "All Notes";
}
@model List<SharpNotes.Models.Note>

<div class="text-center">
    <h1 class="display-4 mb-4">@ViewData["Title"]</h1>
    <table class="table table-striped">
        <thead class="thead-dark">
            <tr>
                <th scope="col">#</th>
                <th scope="col">Title</th>
                <th scope="col">Created at</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var note in Model)
            {
                <tr>
                    <th scope="row">@note.Id</th>
                    <td>@note.Title</td>
                    <td>@note.Created</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-dark btn-sm">Edit</a>
                        <a asp-action="Details" asp-route-id="@note.Id" class="btn btn-info btn-sm">Details</a>
                        <form asp-action="Delete" asp-route-id="@note.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" onclick="return confirm('Are you sure to delete #@note.Id @note.Title?');" class="btn btn-danger btn-sm">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
