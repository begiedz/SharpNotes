@{
    ViewData["Title"] = "All Notes";
}
@model List<SharpNotes.Models.Note>

<div class="text-center">
    <h1 class="display-4 mb-4">@ViewData["Title"]</h1>
    <table class="table table-striped">
        <thead class="thead-light"">
            <tr>
                <th scope=" col">#</th>
                <th scope="col">Title</th>
                <th scope="col">Created at</th>
                <th scope="col">Actions</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var note in Model)
            {
                <tr>
                    <th scope="row">@note.Id</th>
                    <td>@note.Title</td>
                    <td>@note.Created</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@note.Id">Edit</a> |
                        <a asp-action="Details" asp-route-id="@note.Id">Details</a> |
                        <a asp-action="Delete" asp-route-id="@note.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
