@{
    ViewData["Title"] = "New Note";
}
@model SharpNotes.Models.Note

<h1 class="text-center">@ViewData["Title"]</h1>
<form asp-action="Create" method="post" class="d-flex flex-column gap-3">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="Title">Title</label>
        <input asp-for="Title" type="text" class="form-control" placeholder="Enter title">
        </div>
        <div class="form-group">
            <label asp-for="Content">Content</label>
            <textarea asp-for="Content" class="form-control" placeholder="Enter note content" rows="4"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
    </form>
